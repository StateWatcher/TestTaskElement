# ── Секреты: обязательны, задаёт пользователь. Без них compose не стартует ──
POSTGRES_PASSWORD=change-me
AUTH_SECRET_KEY=change-me-to-long-random-string
AUTH_SUPERUSER_LOGIN=admin
AUTH_SUPERUSER_PASSWORD=change-me

# ── Технические параметры: имеют дефолты, менять по необходимости ──
# Каждое значение задаётся ровно здесь и нигде больше: его читают
# и контейнер postgres, и бэкенд (docker-compose.yml подставляет).
#POSTGRES_USER=app
#POSTGRES_DB=lots
#POSTGRES_PORT=5432
#BACKEND_PORT=8000
#FRONTEND_PORT=5173
# true за HTTPS/TLS-терминацией (nginx/балансировщик), иначе браузер не отдаст cookie обратно
#AUTH_COOKIE_SECURE=false
# Нужен только для `pnpm dev` без Vite-прокси: в docker фронт и API живут
# на одном origin (nginx проксирует /api), и CORS там не участвует.
#APP_CORS_ORIGINS=["http://localhost:5173"]
